# Copy to `.env.local` in the SAME folder as `package.json` (project root).
# After any change to `.env.local`, stop the dev server completely and run `npm run dev` again.

# Database: AcademicNexus on cluster0.cmqv0w0.mongodb.net
# No spaces around `=`. Do not wrap the whole URI in quotes unless your password has spaces.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.cmqv0w0.mongodb.net/AcademicNexus?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=replace-with-a-long-random-string-in-production

# Book cover uploads (production / deployed builds). Create a free account at https://cloudinary.com
# Dashboard → API Keys: copy Cloud name, API Key, API Secret.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- If connection still fails ---
# 1) Atlas → Network Access: add your current IP or 0.0.0.0/0 (testing only).
# 2) Atlas → Database Users: confirm user + password; reset password if unsure.
# 3) Password special characters MUST be percent-encoded in the URI, e.g.:
#    @ → %40   # → %23   $ → %24   & → %26   + → %2B   / → %2F   : → %3A   ? → %3F
#    Example: password "p@ss&word" → use p%40ss%26word between : and @ in the URI.
# 4) In Atlas "Connect", choose Drivers → copy the SRV string, then replace <password>.
